# Application
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Model
MODEL_NAME=microsoft/deberta-v3-large
MODEL_PATH=./artifacts/models/preference_model
MAX_SEQ_LENGTH=1024
INFERENCE_BATCH_SIZE=16
DEVICE=cpu

# Database
DATABASE_URL=postgresql+asyncpg://chatcielo:chatcielo@localhost:5432/chatcielo
REDIS_URL=redis://localhost:6379/0

# Training
TRAIN_DATA_PATH=./data/train.parquet
VAL_DATA_PATH=./data/val.parquet
OUTPUT_DIR=./artifacts/models
NUM_EPOCHS=3
LEARNING_RATE=1e-5
BATCH_SIZE=8
GRADIENT_ACCUMULATION_STEPS=4

# Monitoring
PROMETHEUS_PORT=9090
ENABLE_TRACING=false

# Security / LGPD
PII_AUDIT_ENABLED=true
DATA_RETENTION_DAYS=90
CONSENT_REQUIRED=true
ANONYMIZATION_SALT=change-me-in-production
