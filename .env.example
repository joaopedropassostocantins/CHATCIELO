# ─────────────────────────────────────────────────────────────
# CHATCIELO — Environment Variables Template
# Copie para .env e preencha os valores antes de executar.
# NUNCA commite o arquivo .env real.
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
APP_ENV=development              # development | staging | production
APP_SECRET_KEY=change-me-in-production
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ── Model ────────────────────────────────────────────────────
MODEL_NAME=microsoft/deberta-v3-large
MODEL_PATH=./artifacts/models/preference_model
MAX_SEQ_LENGTH=1024              # must be power of 2, max 2048
INFERENCE_BATCH_SIZE=16
DEVICE=cpu                       # cpu | cuda | mps

# Challenger model for A/B testing (leave empty to disable)
CHALLENGER_MODEL_PATH=

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://chatcielo:chatcielo@localhost:5432/chatcielo
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600             # cache TTL in seconds

# ── Training ─────────────────────────────────────────────────
TRAIN_DATA_PATH=./data/train.parquet
VAL_DATA_PATH=./data/val.parquet
OUTPUT_DIR=./artifacts/models
NUM_EPOCHS=3
LEARNING_RATE=1e-5
BATCH_SIZE=8
GRADIENT_ACCUMULATION_STEPS=4
WARMUP_RATIO=0.1
LABEL_SMOOTHING=0.1
CLS_LOSS_WEIGHT=0.7
EARLY_STOPPING_PATIENCE=2

# ── A/B Testing ──────────────────────────────────────────────
# Fraction of traffic for challenger model (0.0 = disabled, max 0.5)
AB_CHALLENGER_TRAFFIC=0.0
AB_REDIS_PREFIX=chatcielo:ab:

# ── Monitoring ───────────────────────────────────────────────
PROMETHEUS_PORT=9090
ENABLE_TRACING=false
DRIFT_PSI_THRESHOLD=0.2          # PSI > 0.2 triggers retraining alert

# ── Security / LGPD ──────────────────────────────────────────
PII_AUDIT_ENABLED=true
DATA_RETENTION_DAYS=90
CONSENT_REQUIRED=true
ANONYMIZATION_SALT=change-me-in-production   # usado em HMAC-SHA256
